{
  "name": "mcp-isolated-js",
  "version": "1.0.0",
  "description": "MCP server that executes TypeScript code in an isolated Deno sandbox with host-call plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./plugin-system": {
      "types": "./dist/plugin-system.d.ts",
      "import": "./dist/plugin-system.js"
    },
    "./sandbox-manager": {
      "types": "./dist/sandbox-manager.d.ts",
      "import": "./dist/sandbox-manager.js"
    }
  },
  "bin": {
    "mcp-isolated-js": "dist/cli.js"
  },
  "files": [
    "dist/",
    "sandbox/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts ./src/cli.ts ./src/mcp-server.ts ./src/runner.ts ./src/plugin-system.ts ./src/sandbox-manager.ts ./src/plugin-registration-bridge.ts --outdir dist --target node --external '@modelcontextprotocol/sdk' --external 'zod'",
    "test": "bun test",
    "test:e2e": "bun test test/e2e.test.ts",
    "start": "bun run src/cli.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jiti": "^2.6.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
